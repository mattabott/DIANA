# ================================================================
# Diana bot — configuration file
# Copy this file to .env and fill in real values.
# Never commit .env: it's already in .gitignore.
# ================================================================

# --- Telegram ----------------------------------------------------
# Telegram bot token. Get one from @BotFather on Telegram:
#   /newbot  ->  follow the prompts  ->  copy the token
TELEGRAM_BOT_TOKEN=1234567890:AAHfictiousTokenReplaceWithYourRealBotTokenXyZ

# Allowed chat id. ONLY this chat can use the bot.
# How to find it: open @userinfobot on Telegram and run /start, it will
# reply with your numeric ID.
ALLOWED_CHAT_ID=123456789

# --- Ollama (local LLM) ------------------------------------------
OLLAMA_HOST=http://localhost:11434
# Recommended multimodal model (see README for alternatives)
OLLAMA_MODEL=qwen3.5:4b
# How long to keep the model warm in RAM between requests. "24h" avoids
# the ~30s reload on the first message after a pause. "-1" = forever.
OLLAMA_KEEP_ALIVE=24h

# --- Storage & logging -------------------------------------------
DB_PATH=./data/chatbot.db
PERSONA_FILE=./config/persona.yaml
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Autonomous messages (bot writes on its own) -----------------
AUTONOMOUS_ENABLED=true
AUTONOMOUS_MIN_HOUR=9
AUTONOMOUS_MAX_HOUR=23
AUTONOMOUS_MAX_PER_DAY=3
AUTONOMOUS_CHECK_INTERVAL_MIN=30
# false = no autonomous messages on weekends (Saturday+Sunday)
AUTONOMOUS_WEEKEND=false

# --- Photo generation (Stable Horde) -----------------------------
# Free anonymous API key; register at https://stablehorde.net to get
# kudos and higher queue priority.
HORDE_API_KEY=0000000000
# Preferred model list (Horde picks the first free worker). These are
# photoreal/NSFW-friendly; tune as you prefer.
HORDE_MODELS=ICBINP,Realistic Vision,Photon,epiCPhotoGasm
HORDE_NSFW=true
# Fixed seed = more consistent subject across photos. Change it if you
# don't like the face the model produces.
HORDE_SEED=31415
# If true, and you've uploaded references via /setref, img2img is used
# (more face consistency). WARNING: img2img on Horde tends to be
# monotonous in scenes. Default false = txt2img.
HORDE_USE_REF=false

# Daily photo quota (manual + reactive + autonomous share it)
PIC_MAX_PER_DAY=10
PIC_COOLDOWN_MIN=5
# Probability (%) that an autonomous tick becomes a photo instead of text
PIC_AUTONOMOUS_PROB=30

# --- Text-to-speech (Piper, local CPU) ---------------------------
# If true, N% of text replies are synthesized as Telegram voice messages
# (native waveform + playback). Requires ffmpeg installed on the system.
# Download a voice model (.onnx + .onnx.json) from
# https://huggingface.co/rhasspy/piper-voices and put it in data/voices/.
VOICE_ENABLED=false
VOICE_PROBABILITY=40
VOICE_MAX_CHARS=400
TTS_VOICE_MODEL=en_US-amy-medium.onnx
